---
pagination:
  data: logs
  size: 50
permalink: "updatelog/{% if pagination.pageNumber == 0 %}index{% else %}page-{{ pagination.pageNumber | plus: 1 }}{% endif %}.html"
---
<!DOCTYPE html>
<html>
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>KiwiMeowo's History</title>
    <link rel="icon" type="image/x-icon" href="/favicon.ico?">
    <link href="/style.css" rel="stylesheet" type="text/css" media="all">
    <link href="/emote.css" rel="stylesheet" type="text/css" media="all">
    <link href="/style-my-tooltips.css" rel="stylesheet" type="text/css" />
    <script src="http://ajax.googleapis.com/ajax/libs/jquery/1.7/jquery.min.js"></script>
    <script src="/jquery.style-my-tooltips.js"></script>
  </head>
  <style>
    :root{
      --star:linear-gradient(#130F47,#592991);
    }
    .blognav {
  position:fixed;
  z-index: 99;
  width: 100%;
  background: rgb(15 14 49 / 50%); 
  bottom:0;
  padding: 10px 0;
  display: flex;
justify-content: space-around;
  }
  .blognav a,.blognav span:not(a span){
    filter: var(--dropshadow);
    display: inline-block;
    padding:3px 6px;
  }
  .blognav span:not(a span){
    color: var(--yellow);
  }
  .blognav a {
  background: var(--yellow);
  filter: var(--dropshadow);
  border-radius: 5px;
  color: var(--blue);
  text-decoration-color: var(--blue);
  }
  .blognav a span{
    border-radius: 5px;
    padding: 0 7.5px;
    filter: var(--dropshadow);
    background: linear-gradient(135deg, var(--gradient1),var(--gradient2));
  }
  .blognav a:hover,.blognav a:focus{
    background: #bcb9d6de;
    transition: background 0.5s;
  translate:var(--down);
  filter:var(--dropshadowdown);
}
  </style>
 <body>
    <nav>
    <a href="/sitemap.html" style="--svg:url(/assets/map.svg)"></a>
      <a href="/index.html" style="--svg:url(/assets/home.svg)"></a>
  </nav>
  <div class="blognav">
      {% if pagination.href.previous %}<a href="{{ pagination.href.first }}">{% endif %}<span>⇤ First</span>{% if pagination.href.previous %}</a>{% endif %}
      {% if pagination.href.previous %}<a href="{{ pagination.href.previous }}">{% endif %}<span>⭠ Previous</span>{% if pagination.href.previous %}</a>{% endif %}
        {% if pagination.href.next %}<a href="{{ pagination.href.next }}">{% endif %}<span>Next ⭢</span>{% if pagination.href.next %}</a>{% endif %}
        {% if pagination.href.next %}<a href="{{ pagination.href.last }}">{% endif %}<span>Last ⇥</span>{% if pagination.href.next %}</a>{% endif %}
  </div>
  <main>
    <section class="wide">
      <article><h1>Update Log</h1>
        <div class="inner min">
        {% for log in pagination.items %}
        <ul>
        {% for info in log.infos %}
        <li>{{ info | safe }}</li>
        {% endfor %}
        <p class="date">( {{ log.date }} )</p>
        </ul>
        <hr>
    {% endfor %}
        {% if page.url == pagination.href.last %}<a href="/secret/old/index.html" style="background: none;border: none;margin: auto;display: block;filter: invert(48%) sepia(79%) saturate(2410%) hue-rotate(148deg) brightness(95%) contrast(119%) var(--dropshadow);cursor:pointer;"><img src="/assets/star.svg" style="height:64px;"></a>{% endif %}
      </div>
    </article>
</section>
</main>
</body>
</html>