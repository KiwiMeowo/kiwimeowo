---
pagination:
  data: dreams.dreams
  size: 20
permalink: "blog/dreams/{% if pagination.pageNumber == 0 %}index{% else %}page-{{ pagination.pageNumber | plus: 1 }}{% endif %}.html"
---
<!DOCTYPE html>
<html>
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="Cache-Control" content="no-cache">
    <title>Welcome to my land of Dreams ⋆</title>
    <link rel="icon" type="image/x-icon" href="/favicon.ico?">
    <link href="/style.css" rel="stylesheet" type="text/css" media="all">
    <link href="/emote.css" rel="stylesheet" type="text/css" media="all">
    <link href="dreams.css" rel="stylesheet" type="text/css" media="all">
    <link href="/style-my-tooltips.css" rel="stylesheet" type="text/css" />
    <script src="http://ajax.googleapis.com/ajax/libs/jquery/1.7/jquery.min.js"></script>
    <script src="/jquery.style-my-tooltips.js"></script>
  </head>
  <nav>
    <a href="/sitemap.html" style="--svg:url(/assets/map.svg)"></a>
      <a href="/index.html" style="--svg:url(/assets/home.svg)"></a>
      <a href="/blog/index.html">Blog</a>
  </nav>
  <div class="blognav">
      {% if pagination.href.previous %}<a href="{{ pagination.href.first }}">{% endif %}<span>⇤ First</span>{% if pagination.href.previous %}</a>{% endif %}
      {% if pagination.href.previous %}<a href="{{ pagination.href.previous }}">{% endif %}<span>⭠ Previous</span>{% if pagination.href.previous %}</a>{% endif %}
        {% if pagination.href.next %}<a href="{{ pagination.href.next }}">{% endif %}<span>Next ⭢</span>{% if pagination.href.next %}</a>{% endif %}
        {% if pagination.href.next %}<a href="{{ pagination.href.last }}">{% endif %}<span>Last ⇥</span>{% if pagination.href.next %}</a>{% endif %}
  </div>
  <header></header>
    <div class="title">
      <div class="title-text">
      <h1>Sweet Dreams are made of this ⋆ <a href="art/feed.xml" target="_blank"><svg version="1.1" id="Capa_1" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" viewBox="0 0 455.731 455.731" xml:space="preserve" fill="#000000" style="height:1em;border-radius:2.5px;" class="button"><g id="SVGRepo_bgCarrier" stroke-width="0"></g><g id="SVGRepo_tracerCarrier" stroke-linecap="round" stroke-linejoin="round"></g><g id="SVGRepo_iconCarrier"><g><rect x="0" y="0" style="fill:var(--blue);" width="455.731" height="455.731"></rect><g><path style="fill:#a037e7;" d="M296.208,159.16C234.445,97.397,152.266,63.382,64.81,63.382v64.348 c70.268,0,136.288,27.321,185.898,76.931c49.609,49.61,76.931,115.63,76.931,185.898h64.348 C391.986,303.103,357.971,220.923,296.208,159.16z"></path><path style="fill:#a037e7;" d="M64.143,172.273v64.348c84.881,0,153.938,69.056,153.938,153.939h64.348 C282.429,270.196,184.507,172.273,64.143,172.273z"></path><circle style="fill:#a037e7;" cx="109.833" cy="346.26" r="46.088"></circle></g></g></g></svg></a></h1>
      </div>
    </div>
 <body>
    <main>
    <section class="wide">
    {% for dream in pagination.items %}
    <article>
    <div class="inner">
    <h1>{{ dream.date }}</h1>
    <p class="tags">Category: {{ dream.category }} | Rating: {{ dream.rating }}</p>
    {{ dream.detail | safe }}
    {% if dream.long and dream.long != 'false' %}
    <p class="more"><a href="{{ dream.long }}">Read more -&gt;</a></p>
    {% endif %}
    </div>
    </article>
    {% endfor %}
    </section>
    </main>
</body>
</html>