<!DOCTYPE html>
<html>
<head>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@4.4.1/dist/css/bootstrap.min.css" integrity="sha384-Vkoo8x4CGsO3+Hhxv8T/Q5PaXtkKtu6ug5TOeNV6gBiFeWPGFN9MuhOf23Q9Ifjh" crossorigin="anonymous">
<style>
body{
  background-color: #272727;
    color:white;
}
</style>
</head>
<body>

<div style="text-align:center;font-size:1.1em;;margin:15px;border:4px solid {{ yellow }};border-radius:2px;">
<div style="background:{{ yellow }};color:{{ teal }};margin:5px;padding:15px;">
<p style="font-family:Georgia;font-size:1.25em;"><i>&quot;{{ desc | safe }}&quot;</i></p>
<p style="font-size:0.8em">⋄ ⋆ ☆ ⋆ ⋄</p>
<div class="row container-md" style="margin:auto;">
<div class="col-md-6">
<p style="color:{{ blue }};font-size:1.25em;"><span style="border-bottom:4px double {{ lteal }}">⋄ ⋆&nbsp;<span style="font-family:Georgia;">{{ pronoun }} Lore Stuff</span>&nbsp;⋆ ⋄</span></p>
<p><span style="color:{{ lteal }};">{% if symbol %}{{ symbol }}{% else %}☆{% endif %}</span> <span style="font-family:Georgia;">Height: {{ height }}cm</span></p>
{% for fact in lorefacts %}
<p><span style="color:{{ lteal }};">{% if symbol %}{{ symbol }}{% else %}☆{% endif %}</span> <span style="font-family:Georgia;">{{ fact | safe }}</span></p>
{% endfor %}
</div>
<div class="col-md-6">
<p style="color:{{ blue }};font-size:1.25em;"><span style="border-bottom:4px double {{ lteal }}">⋄ ⋆&nbsp;<span style="font-family:Georgia;">Random Trivia</span>&nbsp;⋆ ⋄</span></p>
{% for triv in metafacts %}
<p><span style="color:{{ lteal }};">{% if symbol %}{{ symbol }}{% else %}☆{% endif %}</span> <span style="font-family:Georgia;">{{ triv | safe }}</span><p>
{% endfor %}
</div>
</div>
<p style="font-size:0.8em">⋄ ⋆ ☆ ⋆ ⋄</p>
</div>
</div>

<center><input type="text">
<button onclick="var copyText = document.querySelector('input');copyText.value=document.querySelectorAll('body>div')[0].outerHTML;copyText.select();navigator.clipboard.writeText(copyText.value);">Copy</button></center>
<hr>
{% if extras %}
<div style="text-align:center;font-size:1.1em;;margin:15px;border:4px solid {{ yellow }};border-radius:2px;">
<div style="background:{{ yellow }};color:{{ teal }};margin:5px;padding:15px;">
<p style="color:{{ blue }};font-size:1.25em;"><span style="border-bottom:4px double {{ lteal }}">⋄ ⋆&nbsp;<span style="font-family:Georgia;">Extra character notes</span>&nbsp;⋆ ⋄</span></p>
{% for extra in extras %}
<p><span style="color:{{ lteal }};">{% if symbol %}{{ symbol }}{% else %}☆{% endif %}</span> <span style="font-family:Georgia;">{{ extra | safe }}</span><p>
{% endfor %}
<p style="font-size:0.8em">⋄ ⋆ ☆ ⋆ ⋄</p>
</div>
</div>
{% endif %}
<center><button onclick="var copyText = document.querySelector('input');copyText.value=document.querySelectorAll('body>div')[1].outerHTML;copyText.select();navigator.clipboard.writeText(copyText.value);">Copy</button></center>
</body>
</html>